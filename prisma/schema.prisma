// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())

  name          String
  email         String    @unique
  password      String

  image         String?
  bio           String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  favorites     Favorite[]
  watchlists    Watchlist[]
  histories     WatchHistory[]
  recommendations Recommendation[]

  @@index([email])

  @@map("users")
}

model Movie {
  id                 Int       @id

  title              String
  overview           String?

  posterPath         String?
  backdropPath       String?

  trailerPath        String?

  releaseDate        String?

  voteAverage        Float?
  popularity         Float?

  genres             String

  runtime            Int?

  originalLanguage   String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  favorites          Favorite[]
  watchlists         Watchlist[]
  histories          WatchHistory[]
  recommendations    Recommendation[]

  @@index([title])
  @@index([popularity])
  @@index([voteAverage])

  @@map("movies")
}

model Watchlist {
  id          String    @id @default(cuid())

  userId      String
  movieId     Int

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  movie       Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@unique([userId, movieId])

  @@index([userId])
  @@index([movieId])

  @@map("watchlists")
}

model Favorite {
  id          String    @id @default(cuid())

  userId      String
  movieId     Int

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  movie       Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@unique([userId, movieId])

  @@index([userId])
  @@index([movieId])

  @@map("favorites")
}

model Recommendation {
  id            String    @id @default(cuid())

  userId        String
  movieId       Int

  score         Float?
  reason        String?

  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  movie         Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([movieId])

  @@map("recommendations")
}

model WatchHistory {
  id            String    @id @default(cuid())

  userId        String
  movieId       Int

  watchedAt     DateTime  @default(now())

  progress      Float?

  completed     Boolean   @default(false)

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  movie         Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([movieId])

  @@map("watch_history")
}